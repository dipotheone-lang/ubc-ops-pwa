{
  "name": "ubc-ops-pwa",
  "version": "1.0.0",
  "private": true,
  "description": "United Brothers Co. internal operations PWA — Apps Script + Sheets + Drive headless backend, offline-first vanilla PWA frontend.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "icons": "node scripts/make-icons.mjs",
    "check": "node scripts/check-syntax.mjs",
    "push": "cd backend && clasp push",
    "deploy:apps": "cd backend && clasp deploy --description \"ubc-ops\"",
    "login": "clasp login",
    "serve": "node scripts/serve.mjs",
    "deploy:firebase": "firebase deploy --only hosting"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
